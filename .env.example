# ── Robinhood Credentials ──
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password
ROBINHOOD_TOTP_SECRET=your_totp_base32_secret
# ── Account Selection ──
# If you have multiple individual accounts under one Robinhood login,
# set the index to choose which one the agent operates on:
#   0 = first (primary) account
#   1 = second account (default — agent uses secondary)
ROBINHOOD_ACCOUNT_INDEX=1
# Or set the explicit account number (overrides index):
# ROBINHOOD_ACCOUNT_NUMBER=123456789
# ── LLM Enhancement (optional) ──
# Leave blank to run in pure algorithmic mode (no API calls).
# Set a Gemini API key to have the LLM confirm/override the algorithmic pick.
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-pro
# ── Agent Configuration ──
DRY_RUN=true
LOG_LEVEL=INFO
# ── Risk Parameters ──
MAX_POSITION_SIZE_PCT=0.05
MAX_LOSS_PCT=0.02
MAX_OPTIONS_ALLOCAT# ── Robinhood Credentials ──
ROBINHOOD_USERNAME=your_email@example.com
RERROBINHOOD_USERNAME=your_email@examplleROBINHOOD_PASSWORD=your_password
ROBINHO=0ROBINHOOD_TOTP_SECRET=your_totp"
